# Core gateway runtime
OPENCLAW_GO_GATEWAY_TOKEN=
OPENCLAW_GO_GATEWAY_AUTH_MODE=token
OPENCLAW_GO_WS_BIND=0.0.0.0:8765
OPENCLAW_GO_HTTP_BIND=0.0.0.0:8766
OPENCLAW_GO_STATE_PATH=/var/lib/openclaw-go/state.json

# Optional channels
OPENCLAW_GO_TELEGRAM_BOT_TOKEN=
OPENCLAW_GO_TELEGRAM_DEFAULT_TARGET=

# Browser bridge integration (enabled via docker-compose.bridge.yml)
OPENCLAW_GO_BROWSER_BRIDGE_ENDPOINT=http://openclaw-browser-bridge:43010
OPENCLAW_CHATGPT_BRIDGE_HOST=0.0.0.0
OPENCLAW_CHATGPT_BRIDGE_PORT=43010
